{
  "name": "ng-simple-state-management",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "build:ace-editor": "ng build --project=ngssm-ace-editor --configuration=production",
    "build:ag-grid": "ng build --project=ngssm-ag-grid --configuration=production",
    "build:data": "ng build --project=ngssm-data --configuration=production",
    "build:navigation": "ng build --project=ngssm-navigation --configuration=production",
    "build:remote-data": "ng build --project=ngssm-remote-data --configuration=production",
    "build:schematics": "ng build --project=ngssm-schematics && cd projects/ngssm-schematics && npm run build",
    "build:shell": "ng build --project=ngssm-shell --configuration=production",
    "build:smusdi": "ng build --project=ngssm-smusdi --configuration=production",
    "build:store": "ng build --project=ngssm-store --configuration=production",
    "build:toolkit": "ng build --project=ngssm-toolkit --configuration=production",
    "build:tree": "ng build --project=ngssm-tree --configuration=production",
    "test:ag-grid": "ng test --no-watch --project=ngssm-ag-grid --coverage",
    "test:data": "ng test --no-watch --project=ngssm-data --coverage",
    "test:navigation": "ng test --no-watch --project=ngssm-navigation --coverage",
    "test:remote-data": "ng test --no-watch --project=ngssm-remote-data --coverage",
    "test:shell": "ng test --no-watch --project=ngssm-shell --coverage",
    "test:smusdi": "ng test --no-watch --project=ngssm-smusdi --coverage",
    "test:store": "ng test --no-watch --project=ngssm-store --coverage",
    "test:toolkit": "ng test --no-watch --project=ngssm-toolkit --coverage",
    "test:tree": "ng test --no-watch --project=ngssm-tree --coverage",
    "link:schematics": "npm link ./dist/ngssm-schematics",
    "build:ci": "npm run build:store && npm run build:toolkit && npm run build:schematics && npm run build:remote-data && npm run build:navigation && npm run build:ag-grid && npm run build:ace-editor && npm run build:shell && npm run build:tree && npm run build:data && npm run build:smusdi",
    "test:ci": "npm run test:store && npm run test:toolkit && npm run test:remote-data && npm run test:navigation && npm run test:ag-grid && npm run test:shell && npm run test:data && npm run test:smusdi && npm run test:tree"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "22.0.3",
    "@angular/common": "22.0.5",
    "@angular/compiler": "22.0.5",
    "@angular/core": "22.0.5",
    "@angular/forms": "22.0.5",
    "@angular/material": "22.0.3",
    "@angular/platform-browser": "22.0.5",
    "@angular/router": "22.0.5",
    "@fortawesome/fontawesome-free": "7.3.0",
    "ace-builds": "1.44.0",
    "ag-grid-angular": "36.0.0",
    "ag-grid-community": "36.0.0",
    "ag-grid-enterprise": "36.0.0",
    "immutability-helper": "3.1.1",
    "luxon": "3.7.2",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.5",
    "@angular/cli": "22.0.5",
    "@angular/compiler-cli": "22.0.5",
    "@eslint/js": "10.0.1",
    "@types/luxon": "3.7.2",
    "@types/node": "26.1.0",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "angular-eslint": "22.0.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "jsdom": "29.1.1",
    "ng-packagr": "22.0.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
